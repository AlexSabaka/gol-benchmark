{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run preview:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npx eslint:*)",
      "Bash(npx shadcn:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vite:*)",
      "Bash(cd frontend && npm:*)",
      "Bash(cd frontend && npx:*)",
      "Bash(cd frontend && ./node_modules/.bin/eslint:*)",
      "Bash(./node_modules/.bin/eslint:*)",
      "Bash(./node_modules/.bin/tsc:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/eslint-frontend-on-edit.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/keybindings-sync-nudge.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/nav-items-nudge.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/type-drift-sentinel.sh"
          }
        ]
      }
    ]
  }
}
